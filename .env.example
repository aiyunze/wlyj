# 时光邮局环境变量配置
# 复制此文件为 .env.local 并填入实际值

# ==================== 基础配置 ====================
# 管理后台登录用户名（不设置则默认为 admin）
ADMIN_USERNAME=admin

# 管理后台登录密码（不设置则默认为 admin123）
ADMIN_PASSWORD=your-password-here

# Cron API 密钥（可选，设置后需要在请求时携带 X-Cron-Key 头或 ?key= 参数）
CRON_API_KEY=your-cron-secret-key

# 网站域名（用于生成附件完整URL）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# ==================== Cloudflare D1 数据库（生产环境） ====================
# D1 数据库 ID（Cloudflare 控制台获取）
# D1_DATABASE_ID=your-d1-database-id

# ==================== Cloudflare R2 存储（生产环境） ====================
# R2 公开访问域名（通过 Cloudflare Workers 或自定义域名配置）
# R2_CUSTOM_DOMAIN=https://your-r2-domain.com
# R2_PUBLIC_URL=https://your-r2-domain.com

# ==================== R2 存储（开发环境，使用 AWS SDK） ====================
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET=your-bucket-name
# R2_REGION=auto

# ==================== 腾讯云 COS 存储（可选） ====================
# COS_SECRET_ID=your-cos-secret-id
# COS_SECRET_KEY=your-cos-secret-key
# COS_BUCKET=your-cos-bucket
# COS_REGION=ap-guangzhou

# ==================== 阿里云 OSS 存储（可选） ====================
# OSS_ACCESS_KEY_ID=your-oss-access-key
# OSS_ACCESS_KEY_SECRET=your-oss-secret
# OSS_BUCKET=your-oss-bucket
# OSS_REGION=oss-cn-hangzhou

# ==================== 七牛云 Kodo 存储（可选） ====================
# KODO_ACCESS_KEY=your-kodo-access-key
# KODO_SECRET_KEY=your-kodo-secret-key
# KODO_BUCKET=your-kodo-bucket
# KODO_REGION=z0
